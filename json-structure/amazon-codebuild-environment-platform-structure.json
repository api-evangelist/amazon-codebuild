{
  "$schema": "https://json-structure.org/meta/core/v0/#",
  "$id": "https://raw.githubusercontent.com/api-evangelist/amazon-codebuild/refs/heads/main/json-structure/amazon-codebuild-environment-platform-structure.json",
  "name": "EnvironmentPlatform",
  "description": "A set of Docker images that are related by platform and are managed by CodeBuild.",
  "type": "object",
  "properties": {
    "platform": {
      "allOf": [
        {
          "$ref": "#/components/schemas/PlatformType"
        },
        {
          "description": "The platform's name."
        }
      ]
    },
    "languages": {
      "allOf": [
        {
          "$ref": "#/components/schemas/EnvironmentLanguages"
        },
        {
          "description": "The list of programming languages that are available for the specified platform."
        }
      ]
    }
  }
}